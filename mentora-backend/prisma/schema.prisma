generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  parent
  mentor
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  students  Student[]
  lessons   Lesson[]
  createdAt DateTime @default(now())
}

model Student {
  id        String   @id @default(uuid())
  name      String
  age       Int
  parentId  String
  parent    User     @relation(fields: [parentId], references: [id])
  bookings  Booking[]
  createdAt DateTime @default(now())
}

model Lesson {
  id          String    @id @default(uuid())
  title       String
  description String
  mentorId    String
  mentor      User      @relation(fields: [mentorId], references: [id])
  sessions    Session[]
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}

model Booking {
  id        String   @id @default(uuid())
  studentId String
  lessonId  String
  student   Student @relation(fields: [studentId], references: [id])
  lesson    Lesson  @relation(fields: [lessonId], references: [id])
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(uuid())
  lessonId  String
  date      DateTime
  topic     String
  summary   String
  lesson    Lesson @relation(fields: [lessonId], references: [id])
  createdAt DateTime @default(now())
}